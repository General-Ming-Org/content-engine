# Copy to terraform.tfvars and fill in. Never commit terraform.tfvars.

project_id               = "your-gcp-project-id"
google_credentials_file  = "gcp-sa.json"
terraform_operator_email = "terraform-deployer@your-gcp-project-id.iam.gserviceaccount.com"
enable_github_wif        = true
region                   = "us-central1"
zone                     = "us-central1-a"
github_repo              = "General-Ming-Org/content-engine"
git_branch               = "main"

# Use an EXISTING Cloud DNS zone when the domain already has records (portfolio, email, etc.):
#   dns_managed_zone = "production"
# Or let Terraform create a new zone (only for a fresh domain with no other records):
#   dns_zone_dns_name = "example.com"

domain_name       = "contentengine.example.com"
# dns_managed_zone = "production"
# dns_zone_dns_name = "example.com"

# e2-standard-2 (8 GB) recommended for local Docker builds; e2-medium (4 GB) if CI pushes images.
# vm_machine_type = "e2-standard-2"

# TLS: selfsigned (default) or letsencrypt (certbot; needs DNS delegated to Cloud DNS first).
# tls_mode      = "selfsigned"
# certbot_email = "you@example.com"

# With nginx TLS, only 80/443 (+ 8002 for Knowledge MCP) need to be public.
# allowed_ingress_ports = ["80", "443", "8002"]

# ── Secrets — fill in terraform.tfvars, then run `terraform apply` ────────────

anthropic_api_key      = ""
voyage_api_key         = ""
openai_api_key         = ""
tavily_api_key         = ""
substack_email         = ""
substack_password      = ""
# Resend: host=smtp.resend.com, port=587, username=resend, password=<API key>,
# from=<verified domain address>. Gmail uses smtp.gmail.com + App Password.
smtp_host              = "smtp.gmail.com"
smtp_username          = ""
smtp_password          = ""
smtp_from_address      = ""
smtp_to_address        = ""

app_secret_key      = ""
dashboard_password  = ""
qdrant_api_key      = ""
mcp_knowledge_token = ""
postgres_password   = ""

# llm_provider       = "openai"
# llm_model          = "gpt-4o-mini"
# embedding_provider = "openai"
# embedding_model    = "text-embedding-3-small"
