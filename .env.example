# =============================================================================
# CONTENT ENGINE — Environment Variables
# Copy this file to .env and fill in all values before running.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM providers (operator-paid — shared across all users)
#
# Specify exactly one LiteLLM provider and model. The backend combines these as
# "<provider>/<model>" for every LLM task.
#
# Examples:
#   LLM_PROVIDER=anthropic
#   LLM_MODEL=claude-sonnet-4-6
#   LLM_PROVIDER=openai
#   LLM_MODEL=gpt-4o-mini
# -----------------------------------------------------------------------------
LLM_PROVIDER=
LLM_MODEL=

# Prompt caching gives a 90% discount on cached prefix tokens. Only honoured
# when the resolved model's provider supports it (Anthropic today; ignored for
# other providers).
ANTHROPIC_PROMPT_CACHING=true

# Provider API keys — only set the one matching LLM_PROVIDER, plus any used by
# embeddings/search integrations.
# Get keys from:
#   Anthropic:  https://console.anthropic.com/
#   OpenAI:     https://platform.openai.com/api-keys
#   Gemini:     https://aistudio.google.com/apikey
#   Mistral:    https://console.mistral.ai/
#   Groq:       https://console.groq.com/keys
#   DeepSeek:   https://platform.deepseek.com/
#   xAI:        https://console.x.ai/
#   OpenRouter: https://openrouter.ai/keys  (one key, access to ~all models)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=

# -----------------------------------------------------------------------------
# Embedding provider — for the vector DB. Switch providers in user_settings;
# the system auto-triggers re-embed of the existing corpus into a new collection.
# Valid combinations:
#   voyage / voyage-3            (1024d, Anthropic-recommended, $0.06/1M)
#   voyage / voyage-3-large      (1024d, top quality, $0.12/1M)
#   openai / text-embedding-3-small  (1536d, cheapest at $0.02/1M)
#   openai / text-embedding-3-large  (3072d, $0.13/1M)
#   cohere / embed-english-v3.0  (1024d, $0.10/1M)
# -----------------------------------------------------------------------------
EMBEDDING_PROVIDER=
EMBEDDING_MODEL=

VOYAGE_API_KEY=
COHERE_API_KEY=
# OPENAI_API_KEY is declared in the LLM section above — reused for OpenAI embeddings.

# -----------------------------------------------------------------------------
# Qdrant vector database
# Local docker-compose includes a Qdrant container — no setup needed.
# API key is optional in dev; required if you expose Qdrant publicly.
# -----------------------------------------------------------------------------
QDRANT_URL=http://qdrant:6333
# Leave empty for local Docker (no Qdrant auth). Do NOT set to "" in compose — that
# enables API-key auth with no key and causes 401 errors. Set only in production.
QDRANT_API_KEY=

# Cosine similarity threshold for dedup + cache hits. Higher = stricter matches.
VECTOR_SIMILARITY_THRESHOLD=0.85

# -----------------------------------------------------------------------------
# MCP servers
# tavily-mcp + knowledge-mcp run as docker-compose services. Backend passes
# these URLs to Claude API calls so Claude can call them as tools.
# MCP_KNOWLEDGE_TOKEN is required only for external clients (Claude Code / Desktop).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# -----------------------------------------------------------------------------
MCP_TAVILY_URL=http://tavily-mcp:8001
MCP_KNOWLEDGE_URL=http://knowledge-mcp:8002

MCP_KNOWLEDGE_TOKEN=

# -----------------------------------------------------------------------------
# Research sweep volume (4 domains × PER_DOMAIN, then capped at MAX_TOPICS)
# Default: 3 per domain → 12 search hits, enrich at most 10 (LLM cost control)
# -----------------------------------------------------------------------------
RESEARCH_SWEEP_PER_DOMAIN=3
RESEARCH_SWEEP_MAX_TOPICS=10

# -----------------------------------------------------------------------------
# Tavily Search API (primary research source — also used by the Tavily MCP)
# Sign up at: https://tavily.com/ — free tier gives 1,000 searches/month
# -----------------------------------------------------------------------------
TAVILY_API_KEY=

# -----------------------------------------------------------------------------
# Serper API (fallback search — optional but recommended)
# Sign up at: https://serper.dev/ — 2,500 free searches
# -----------------------------------------------------------------------------
SERPER_API_KEY=

# -----------------------------------------------------------------------------
# LinkedIn Developer App — configured in the web app (Settings → LinkedIn).
# Each user saves their own Client ID / Client Secret (encrypted in the DB), then
# connects their LinkedIn account. Follow the in-app setup guide for redirect URLs.
#
# Optional legacy fallback (only if you do not use per-user Settings):
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
#
# OAuth redirect (optional). Default: {APP_PUBLIC_URL}/api/publish/linkedin/callback
# Local dev — register THIS in LinkedIn Developer App → Auth → Redirect URLs:
#   http://localhost:3000/api/publish/linkedin/callback
# (Vite proxies /api to the backend; do NOT use http://localhost without port/path.)
# LINKEDIN_REDIRECT_URI=
# -----------------------------------------------------------------------------
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=

# -----------------------------------------------------------------------------
# Substack — no operator-level config.
# Each user enters their own Substack email + password + publication_url in
# Settings; the values are encrypted at rest in user_credentials.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# SMTP — operator's outbound mail (shared across all users)
# Digests go to each user's account email by default (optional override in Settings).
# Gmail example: host=smtp.gmail.com, port=587, use App Password
#   Generate at: myaccount.google.com/apppasswords
#
# Gmail inbox avatar (sender photo) is NOT set from the email HTML — it uses your
# Google account photo when sending via Gmail SMTP, or Gravatar for SMTP_FROM_ADDRESS.
# Upload backend/static/email/icon.png to Gravatar for your From address, using:
#   {API_PUBLIC_URL}/api/brand/icon.png
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=

# -----------------------------------------------------------------------------
# Database
# Change user/pass for production. The docker-compose defaults match these.
# -----------------------------------------------------------------------------
POSTGRES_USER=content_engine
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=content_engine
DATABASE_URL=postgresql://content_engine:devpassword@db:5432/content_engine

# For local dev without Docker (points to localhost instead of service name):
# DATABASE_URL=postgresql://content_engine:devpassword@localhost:5432/content_engine

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
# For local dev without Docker:
# REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# Signs JWT auth tokens AND derives the Fernet key used to encrypt user
# credentials in the DB. ROTATING THIS INVALIDATES every existing JWT and every
# encrypted credential blob — users will need to log in again and re-enter
# LinkedIn / Substack creds.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET_KEY=

# Application environment: development | production
APP_ENV=development

# Public URLs — browser-reachable hosts (not Docker service names like "backend").
# Local Docker Compose (defaults are also set in docker-compose.yml):
#   APP_PUBLIC_URL=http://localhost:3000   # web app (Settings redirect after LinkedIn OAuth)
#   API_PUBLIC_URL=http://localhost:8000 # API + LinkedIn OAuth callback URL
APP_PUBLIC_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:8000

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
